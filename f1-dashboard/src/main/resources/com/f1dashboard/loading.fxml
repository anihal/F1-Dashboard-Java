<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.f1dashboard.ui.LoadingController"
      alignment="CENTER" spacing="20">
  <padding><Insets top="60" right="80" bottom="60" left="80"/></padding>
  <Label text="F1 Analytics Dashboard" styleClass="loading-title"/>
  <Label text="Loading dataset into database..."/>
  <ProgressBar fx:id="progressBar" prefWidth="400"/>
  <Label fx:id="statusLabel" text="Starting..."/>
</VBox>
